@page "/"

<style>
    :root {
        --bg: #050508;
        --surface: #0a0a12;
        --accent: #FF1493;
        --accent-glow: rgba(255, 20, 147, 0.4);
        --text: #f0f0f5;
        --text-dim: #707080;
        --border: rgba(255, 20, 147, 0.15);
        --success: #00ff9d;
    }

    .landing-body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Outfit', sans-serif;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .container-landing {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 1000px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 0 50px rgba(0,0,0,0.5), inset 0 0 20px rgba(255, 20, 147, 0.05);
        backdrop-filter: blur(10px);
    }

    .header-landing {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 20px;
    }

    .logo-landing {
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 2px;
        color: var(--accent);
        text-shadow: 0 0 15px var(--accent-glow);
    }

    .status-landing {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        text-transform: uppercase;
        color: var(--success);
    }

    .status-dot-landing {
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--success);
        animation: pulse-landing 2s infinite;
    }

    @@keyframes pulse-landing {
        0% { opacity: 1; }
        50% { opacity: 0.4; }
        100% { opacity: 1; }
    }

    .hero-landing {
        text-align: center;
        margin-bottom: 60px;
    }

    .hero-landing h1 {
        font-size: 48px;
        margin-bottom: 10px;
        letter-spacing: -1px;
        background: linear-gradient(to right, #fff, var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    p.subtitle-landing {
        color: var(--text-dim);
        font-size: 18px;
        max-width: 600px;
        margin: 0 auto;
    }

    .grid-landing {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .card-landing {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 30px;
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .card-landing:hover {
        background: rgba(255, 20, 147, 0.05);
        border-color: var(--accent);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(255, 20, 147, 0.1);
    }

    .card-landing h3 {
        font-size: 20px;
        margin-bottom: 10px;
        color: var(--accent);
    }

    .card-landing p {
        color: var(--text-dim);
        font-size: 14px;
        line-height: 1.6;
    }

    .footer-landing {
        margin-top: 60px;
        text-align: center;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-dim);
    }

    .terminal-text-landing {
        color: var(--accent);
    }

    /* Glitch Animation */
    .glitch-landing {
        position: relative;
    }

    .glitch-landing::before, .glitch-landing::after {
        content: attr(data-text);
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: var(--surface);
    }

    .glitch-landing::after {
        left: 2px;
        text-shadow: -2px 0 #ff00c1;
        clip: rect(44px, 450px, 56px, 0);
        animation: glitch-anim-landing 5s infinite linear alternate-reverse;
    }

    @@keyframes glitch-anim-landing {
        0% { clip: rect(31px, 9999px, 94px, 0); }
        20% { clip: rect(62px, 9999px, 42px, 0); }
        40% { clip: rect(10px, 9999px, 50px, 0); }
        60% { clip: rect(78px, 9999px, 70px, 0); }
        80% { clip: rect(35px, 9999px, 12px, 0); }
        100% { clip: rect(50px, 9999px, 88px, 0); }
    }
</style>

<div class="landing-body">
    <div class="container-landing">
        <div class="header-landing">
            <div class="logo-landing">AEGIS SEC</div>
            <div class="status-landing">
                <div class="status-dot-landing"></div>
                SYSTEM ONLINE
            </div>
        </div>

        <div class="hero-landing">
            <h1 class="glitch-landing" data-text="Operations Center">Operations Center</h1>
            <p class="subtitle-landing">Secure, fast, and scalable cybersecurity management. Launching the next generation of threat intelligence.</p>
        </div>

        <div class="grid-landing">
            <a href="/dashboard" class="card-landing">
                <h3>Dashboard UI</h3>
                <p>Access the real-time monitoring interface. Built with Blazor WebAssembly and Cyber-Synth design.</p>
            </a>
            <a href="/DATABASE FO INFO SECURITY.txt" target="_blank" class="card-landing">
                <h3>Documentation</h3>
                <p>Review the core system requirements, security protocols, and database schema information.</p>
            </a>
            <a href="/aegis_server_log_final.txt" target="_blank" class="card-landing">
                <h3>System Logs</h3>
                <p>View the latest security event logs and system audit trails from the production environment.</p>
            </a>
        </div>

        <div class="footer-landing">
            [ <span class="terminal-text-landing">INTEGRATED INTERFACE ACTIVE</span> ] &nbsp; | &nbsp; v2.1.0 &nbsp; | &nbsp; <span class="terminal-text-landing">UPLINK ESTABLISHED</span>
        </div>
    </div>
</div>
