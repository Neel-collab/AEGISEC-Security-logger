@page "/users"

<div class="cyber-panel">
    <h3 class="neon-text glitch" data-text="IDENTITY MANAGEMENT">IDENTITY MANAGEMENT</h3>
    <p style="color: var(--text-secondary);">Access to user modification is currently restricted. Clearance level insufficient.</p>
    
    <div style="margin-top: 20px;">
        <div style="display: flex; gap: 20px;">
            <div style="padding: 10px; border: 1px solid var(--neon-pink); color: var(--neon-pink); font-family: monospace;">ACCESS DENIED</div>
            <div style="padding: 10px; border: 1px solid var(--neon-cyan); color: var(--neon-cyan); font-family: monospace;">AWAITING AUTHORIZATION</div>
        </div>
    </div>
</div>
