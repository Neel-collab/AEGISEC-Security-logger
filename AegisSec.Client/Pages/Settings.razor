@page "/settings"

<div class="cyber-panel">
    <h3 class="neon-text glitch" data-text="SYSTEM CONFIGURATION">SYSTEM CONFIGURATION</h3>
    <p style="color: var(--text-secondary);">Manual override required to alter core protocols.</p>
    
    <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 15px;">
        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #333; padding-bottom: 10px;">
            <span>FIREWALL STRICT MODE</span>
            <span style="color: var(--neon-cyan)">[ ENABLED ]</span>
        </div>
        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #333; padding-bottom: 10px;">
            <span>AUTO-PURGE LOGS (7 DAYS)</span>
            <span style="color: var(--neon-pink)">[ DISABLED ]</span>
        </div>
        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #333; padding-bottom: 10px;">
            <span>SATELLITE UPLINK PING</span>
            <span style="color: var(--gold)">[ MANUAL CALIBRATION ]</span>
        </div>
        <div style="display: flex; justify-content: space-between; padding-bottom: 10px;">
            <span style="opacity: 0.5">ADMINISTRATOR ACCESS</span>
            <span style="color: var(--neon-pink); font-family: monospace;">ACCESS DENIED</span>
        </div>
    </div>
</div>
